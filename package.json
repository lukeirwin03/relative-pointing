{
  "name": "relative-pointing-app",
  "version": "1.0.11",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "node server/server.js",
    "build": "npm run build -w client",
    "start": "NODE_ENV=production node server/server.js",
    "start:backend": "node server/server.js",
    "prepare": "husky",
    "test": "npm run build && npm run test:e2e",
    "lint": "prettier --check 'client/src/**/*.{vue,js,json,css}' 'server/**/*.js' 'e2e/**/*.js'",
    "format": "prettier --write 'client/src/**/*.{vue,js,json,css}' 'server/**/*.js' 'e2e/**/*.js'",
    "format:check": "prettier --check 'client/src/**/*.{vue,js,json,css}' 'server/**/*.js' 'e2e/**/*.js'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "client/src/**/*.{vue,js}": [
      "prettier --write"
    ],
    "server/**/*.js": [
      "prettier --write"
    ],
    "e2e/**/*.js": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
