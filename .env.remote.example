# ============================================================================
# REMOTE EC2 DEPLOYMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your EC2 details to enable
# one-command deployment with: ./deploy-remote.sh
#
# Prerequisites:
#   - An EC2 instance running Ubuntu (18.04, 20.04, or 22.04)
#   - Security group allowing inbound ports: 22 (SSH), 80 (HTTP), 443 (HTTPS)
#   - Your SSH key (.pem file) downloaded from AWS
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: EC2 SSH Connection
# ----------------------------------------------------------------------------

# Public IP address or DNS of your EC2 instance
# Find this in AWS Console > EC2 > Instances > Your Instance > Public IPv4 address
EC2_HOST=.env.remote.example

# SSH username (default is 'ubuntu' for Ubuntu AMIs, 'ec2-user' for Amazon Linux)
EC2_USER=ubuntu

# Path to your EC2 SSH private key file (.pem)
# Example: ~/.ssh/my-ec2-keypair.pem
EC2_KEY_PATH=

# ----------------------------------------------------------------------------
# REQUIRED: Domain Configuration
# ----------------------------------------------------------------------------

# Your domain name (must point to EC2_HOST via DNS A record)
# Example: myapp.example.com
EC2_DOMAIN=

# ----------------------------------------------------------------------------
# OPTIONAL: Deployment Settings (defaults shown)
# ----------------------------------------------------------------------------

# AWS region where your EC2 instance is running
AWS_REGION=us-east-2

# Directory on EC2 where the app will be deployed
EC2_APP_DIR=/var/www/relative-pointing

# Node.js version to install via nvm
NODE_VERSION=18.18.0

# Email for Let's Encrypt certificate registration (expiry notifications)
# Defaults to admin@<EC2_DOMAIN> if not set
CERTBOT_EMAIL=

# ----------------------------------------------------------------------------
# LOCAL DEVELOPMENT (used by React app)
# ----------------------------------------------------------------------------

# API URL for local development
REACT_APP_API_URL=http://localhost:5000/api
