#!/bin/bash

# Relative Pointing App - Development Runner
# This script sets up and runs the development environment

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Functions
print_header() {
    echo -e "${BLUE}═══════════════════════════════════════════${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Check if running from project root
if [ ! -f "package.json" ]; then
    print_error "package.json not found. Please run this script from the project root directory."
    exit 1
fi

print_header "Relative Pointing App - Setup & Run"

# 0. Clean database for fresh start
print_info "Cleaning database for fresh development environment..."
rm -f server/app.db
if [ -f "server/app.db" ]; then
    print_warning "Could not delete old database, but continuing anyway..."
else
    print_success "Database cleaned"
fi

# 1. Check Node.js and npm
print_info "Checking Node.js and npm..."

if ! command -v node &> /dev/null; then
    print_error "Node.js is not installed"
    echo "Please install Node.js 18+ from https://nodejs.org/"
    exit 1
fi

NODE_VERSION=$(node -v)
print_success "Node.js $NODE_VERSION found"

if ! command -v npm &> /dev/null; then
    print_error "npm is not installed"
    exit 1
fi

NPM_VERSION=$(npm -v)
print_success "npm $NPM_VERSION found"

# 2. Check/use Node Version Manager if available
# nvm is a shell function, not a binary, so we need to source it first
if [ -f ".nvmrc" ]; then
    NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        print_info "Loading nvm..."
        . "$NVM_DIR/nvm.sh"
        print_info "Using nvm to set Node version from .nvmrc..."
        nvm use || nvm install
        # Re-check node version after nvm switch
        NODE_VERSION=$(node -v)
        print_success "Now using Node.js $NODE_VERSION"
    else
        print_warning "nvm not found. Using system Node.js."
    fi
fi

# 2b. Enforce minimum Node.js version (18+)
NODE_MAJOR=$(node -v | sed 's/v\([0-9]*\).*/\1/')
if [ "$NODE_MAJOR" -lt 18 ]; then
    print_error "Node.js 18+ is required (found $(node -v)). Vite 5 does not support older versions."
    echo "Please install Node.js 18+ or configure nvm with: nvm install 20"
    exit 1
fi

# 3. Check if node_modules exists
if [ ! -d "node_modules" ]; then
    print_info "Installing dependencies (this may take a minute)..."
    npm install
    print_success "Dependencies installed"
else
    print_success "Dependencies already installed"

    # Check if package-lock.json matches
    if [ -f "package-lock.json" ]; then
        print_info "Checking for dependency updates..."
        npm ci --legacy-peer-deps 2>/dev/null || npm install
    fi
fi

# 4. Check .env.local
print_info "Checking environment configuration..."

if [ ! -f ".env.local" ]; then
    print_warning ".env.local not found"
    echo ""
    echo "Creating .env.local from template..."
    cp .env.example .env.local
    print_success "Template created at .env.local"
fi

print_success "Environment configuration OK"

# 5. Show useful information
echo ""
print_header "Starting Development Servers"
echo ""
print_info "Backend API will be available at http://localhost:5000"
print_info "Frontend will be available at http://localhost:3000"
echo ""
print_info "Both servers starting... this may take a moment"
print_info "Press Ctrl+C to stop all servers"
echo ""

# 6. Start both backend and frontend
npm run dev
