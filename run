#!/bin/bash

# Relative Pointing App - Development Runner
# This script sets up and runs the development environment

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Functions
print_header() {
    echo -e "${BLUE}═══════════════════════════════════════════${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Check if running from project root
if [ ! -f "package.json" ]; then
    print_error "package.json not found. Please run this script from the project root directory."
    exit 1
fi

print_header "Relative Pointing App - Setup & Run"

# 1. Check Node.js and npm
print_info "Checking Node.js and npm..."

if ! command -v node &> /dev/null; then
    print_error "Node.js is not installed"
    echo "Please install Node.js 18+ from https://nodejs.org/"
    exit 1
fi

NODE_VERSION=$(node -v)
print_success "Node.js $NODE_VERSION found"

if ! command -v npm &> /dev/null; then
    print_error "npm is not installed"
    exit 1
fi

NPM_VERSION=$(npm -v)
print_success "npm $NPM_VERSION found"

# 2. Check/use Node Version Manager if available
if [ -f ".nvmrc" ] && command -v nvm &> /dev/null; then
    print_info "Using nvm to set Node version from .nvmrc..."
    nvm use || print_warning "Could not switch to specified Node version. Using system Node."
fi

# 3. Check if node_modules exists
if [ ! -d "node_modules" ]; then
    print_info "Installing dependencies (this may take a minute)..."
    npm install
    print_success "Dependencies installed"
else
    print_success "Dependencies already installed"

    # Check if package-lock.json matches
    if [ -f "package-lock.json" ]; then
        print_info "Checking for dependency updates..."
        npm ci --legacy-peer-deps 2>/dev/null || npm install
    fi
fi

# 4. Check .env.local
print_info "Checking environment configuration..."

if [ ! -f ".env.local" ]; then
    print_warning ".env.local not found"
    echo ""
    echo "Creating .env.local from template..."
    cp .env.example .env.local
    print_info "Template created at .env.local"
    echo ""
    echo -e "${YELLOW}⚠️  ACTION REQUIRED:${NC}"
    echo "You need to add your Firebase credentials to .env.local"
    echo ""
    echo "Steps to get Firebase credentials:"
    echo "1. Go to https://console.firebase.google.com"
    echo "2. Create a new project (or select existing)"
    echo "3. Enable Realtime Database (start in test mode)"
    echo "4. Go to Project Settings → Service Accounts → Web"
    echo "5. Copy the config values to .env.local"
    echo ""
    echo "Or follow: docs/FIREBASE_SETUP.md"
    echo ""
    read -p "Press Enter once you've updated .env.local with your Firebase credentials..."
fi

# Validate .env.local has required Firebase config
if ! grep -q "REACT_APP_FIREBASE_API_KEY" .env.local || [ -z "$(grep 'REACT_APP_FIREBASE_API_KEY' .env.local | cut -d= -f2)" ]; then
    print_warning "Firebase API key not configured in .env.local"
    echo "The app may not work without proper Firebase credentials."
    echo ""
    echo "Follow these steps:"
    echo "1. Edit .env.local"
    echo "2. Replace placeholder values with your Firebase credentials"
    echo "3. Save the file"
    echo "4. Run this script again"
    echo ""
    read -p "Continue anyway? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

print_success "Environment configuration OK"

# 5. Show useful information
echo ""
print_header "Starting Development Server"
echo ""
print_info "Server will be available at http://localhost:3000"
print_info "Ctrl+C to stop the server"
echo ""

# Optional: Show sample credentials reminder
if [ -f "docs/FIREBASE_SETUP.md" ]; then
    print_info "Need help with Firebase? See: docs/FIREBASE_SETUP.md"
fi

echo ""

# 6. Start the development server
npm start
