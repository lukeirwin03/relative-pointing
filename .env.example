# ============================================================================
# LOCAL DEVELOPMENT CONFIGURATION
# ============================================================================
# The app runs a local backend server on port 5001
# Frontend dev server uses Vite on port 3000
# No configuration needed for local development - just run `npm run dev`

VITE_API_URL=http://localhost:5001/api

# ============================================================================
# REMOTE EC2 DEPLOYMENT CONFIGURATION
# ============================================================================
# Fill these out to enable one-command remote deployment to EC2

# AWS EC2 SSH Configuration
EC2_HOST=your-ec2-public-ip-or-dns
EC2_USER=ubuntu
EC2_KEY_PATH=~/.ssh/your-ec2-key.pem
EC2_DOMAIN=yourdomain.com

# AWS Region
AWS_REGION=us-east-2

# Deployment Directory on EC2
EC2_APP_DIR=/var/www/relative-pointing
