# Secrets — never bake into the image
.env
.env.*
!.env.example

# VCS and CI
.git
.gitignore
.github
.husky

# Dependencies (reinstalled inside the build)
node_modules
client/node_modules
server/node_modules

# Build artifacts (rebuilt inside the image)
client/dist
build

# Database and runtime data — must never be shipped
*.db
*.db-journal
*.db-wal
*.db-shm
server/app.db

# Tests and reports
e2e
playwright-report
playwright.config.js
test-results
.test-tmp
test.sh

# Host-side log output (bind-mounted at runtime, never baked into image)
logs

# Editor / tool state
.vscode
.idea
.claude
.opencode
.prettierrc

# Local deploy tooling (not used inside container)
deploy.sh
deploy-remote.sh
DEPLOYMENT.md
systemd-services.example
run
sample-tasks.csv
PROJECT_STRUCTURE.txt
SECURITY.md
README.md

# OS junk
.DS_Store
Thumbs.db

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore
